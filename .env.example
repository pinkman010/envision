# ============================================
# ESG AI Expert System - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# 项目基础配置
PROJECT_NAME=ESG AI Expert System
PROJECT_DESCRIPTION=新能源行业ESG披露与沟通智能分析系统（规则驱动为主、AI辅助为辅的强合规工具）
VERSION=1.0.0
API_PREFIX=/api/v1

# 运行环境配置
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# API访问地址（前端/UI连接后端使用）
API_BASE_URL=http://127.0.0.1:8000

# 跨域配置（Streamlit前端访问用）
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# 大模型配置（兼容OpenAI格式）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0
# 禁用推理模型思考能力（适用于 kimi-k2.5, DeepSeek-R1 等推理模型）
# 设置为 true 可禁用思考过程，设置为 false 或不设置则启用思考能力
LLM_THINKING_DISABLED=true

# 硬规则校验阈值
SIMILARITY_THRESHOLD=0.98
MAX_FILE_SIZE=52428800
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(filename)s:%(lineno)d - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# 数据库配置
SQLITE_DB_NAME=esg_system.db
CHROMA_DB_PERSIST_DIR=chroma_db

# Ollama 嵌入模型配置（向量数据库用）
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_WORKERS=4
EMBEDDING_TIMEOUT=60