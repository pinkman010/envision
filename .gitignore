# 环境变量
.env
.env.local

# 临时文件
tmp/
*.tmp
*.temp
*.swp
*.swo
*~

# 数据文件（敏感内容不上传）
# 默认忽略 data 下原始数据与 PDF，仅允许来源清单进入版本控制
data/*
!data/knowledge_base/
data/knowledge_base/*
!data/knowledge_base/manifests/
!data/knowledge_base/manifests/*.json
logs/

# Python缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
venv/
env/
ENV/
*.venv

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# 测试覆盖率
.pytest_cache/
.coverage
htmlcov/

# 构建产物
dist/
build/
*.egg-info/

# Ruff缓存
.ruff_cache/

# 阶段计划与执行记录
docs/superpowers/

# 本地环境与密钥扩展
*.env

# 本地运行日志
*.log

# 本地脚本与调试文件（保留核心 scripts/*.py 进入版本控制）
scripts/tmp/
scripts/local/
scripts/*.local.py
scripts/*_local.py
scripts/*_scratch.py
scripts/*_debug.py
