# ============================================
# ESG AI Expert System - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# 项目基础配置
PROJECT_NAME=ESG AI Expert System
PROJECT_DESCRIPTION=新能源行业ESG披露与沟通智能分析系统（规则驱动为主、AI辅助为辅的强合规工具）
VERSION=1.0.0
API_PREFIX=/api/v1

# 运行环境配置
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# API访问地址（前端/UI连接后端使用）
API_BASE_URL=http://127.0.0.1:8000

# 跨域配置（Streamlit前端访问用）
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# 大模型配置（兼容 OpenAI 格式；P0 E1 使用 DeepSeek）
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=393216
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0

# DeepSeek thinking / JSON Output 配置
# thinking enabled 时不传 temperature/top_p/presence_penalty/frequency_penalty
LLM_THINKING_TYPE=enabled
LLM_REASONING_EFFORT=max
LLM_RESPONSE_FORMAT=json_object

# 兼容旧配置：true 等价于 LLM_THINKING_TYPE=disabled
LLM_THINKING_DISABLED=false

# RAG增强提取配置
USE_RAG_ENHANCEMENT=true
RAG_EXTRACTION_TOP_K=3
RAG_EXTRACTION_THRESHOLD=0.6

# 硬规则校验阈值
SIMILARITY_THRESHOLD=0.98
MAX_FILE_SIZE=52428800
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(filename)s:%(lineno)d - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# 数据库配置
SQLITE_DB_NAME=esg_system.db
CHROMA_DB_PERSIST_DIR=chroma_db

# 嵌入模型配置（硅基流动 API）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_WORKERS=4
EMBEDDING_TIMEOUT=60
