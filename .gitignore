# 过滤敏感配置文件（核心，永不提交）
.env
.env.*
# 过滤Python编译冗余文件
__pycache__/
*.pyc
*.pyo
*.pyd
# 过滤虚拟环境（如果有）
venv/
env/
.venv/
# 过滤日志/临时文件
*.log
temp/
logs/
# 过滤编辑器缓存（可选，如VS Code）
.vscode/
# 忽略所有 PDF 文件
*.pdf
# 忽略所有 DOC 格式文件
*.doc
# 忽略所有 DOCX 格式文件
*.docx
# 可选：若有临时/隐藏的这类文件（如 ~$xxx.docx），也可补充忽略
~$*.docx
~$*.doc
# 忽略所有 bin 格式文件
*.bin
*.sqlite3
*.json